---
import '../styles/global.css'
import { SITE } from '../lib/config'
import NavBar from '../components/NavBar.astro'

interface Props {
  title: string
  description: string
  ogType?: 'website' | 'article' | 'profile'
  ogImage?: string
}

const { title, description, ogType = 'website', ogImage } = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://demo-medical.pages.dev').toString()
const resolvedOgImage = ogImage ?? 'https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=1200&q=80'
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={canonical} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:image" content={resolvedOgImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://images.unsplash.com" />
  <slot name="head" />
</head>
<body class="bg-clean text-charcoal antialiased">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:text-blue focus:border focus:border-blue focus:rounded-md focus:px-4 focus:py-2 focus:shadow-md"
  >
    Skip to main content
  </a>

  <NavBar />

  <main id="main-content"><slot /></main>

  <div class="bg-yellow-50 border-y border-yellow-200 py-3 px-6 text-center">
    <p class="text-xs text-yellow-800">
      <strong>Portfolio Demo</strong> — This is a fictional business created by <a href="https://upstate-web.com" class="underline rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 hover:text-yellow-900">Upstate Web Co</a>. All names, addresses, credentials, and details are entirely fictional. Not a real dental practice.
    </p>
  </div>

  <footer class="bg-charcoal text-white/70">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid md:grid-cols-4 gap-8">
        <div>
          <p class="text-lg font-semibold text-white"><span aria-hidden="true">🦷</span> Bramblewood Dental</p>
          <p class="text-sm mt-2">{SITE.tagline}</p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-white mb-2">Hours</p>
          <p>Mon–Thu: 8am–5pm</p>
          <p>Fri: 8am–2pm</p>
          <p>Sat: By appointment</p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-white mb-2">Contact</p>
          <p>{SITE.address}</p>
          <p class="mt-1"><a href={`tel:${SITE.phone}`} class="rounded hover:text-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">{SITE.phone}</a></p>
          <p><a href={`mailto:${SITE.email}`} class="rounded hover:text-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">{SITE.email}</a></p>
        </div>
        <div class="text-sm">
          <p class="font-medium text-white mb-2">Quick Links</p>
          <p><a href="/about" class="rounded hover:text-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">About</a></p>
          <p><a href="/contact" class="rounded hover:text-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">Contact</a></p>
          <p><a href={SITE.bookingUrl} class="rounded hover:text-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">Book Appointment</a></p>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-white/10 text-center text-xs">
        &copy; {new Date().getFullYear()} {SITE.name}. Built by <a href="https://upstate-web.com" class="text-blue rounded hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">Upstate Web Co</a>
      </div>
    </div>
  </footer>
</body>
</html>
