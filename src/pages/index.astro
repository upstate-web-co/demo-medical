---
import Layout from '../layouts/Layout.astro'
import { SITE, PROVIDERS, SERVICES, INSURANCE, HOURS, WHAT_TO_EXPECT } from '../lib/config'
---

<Layout>
  <!-- Hero -->
  <section class="relative h-[60vh] flex items-center overflow-hidden">
    <img src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=1600&q=80" alt="Modern dental office" class="absolute inset-0 w-full h-full object-cover brightness-[0.35]" loading="eager" />
    <div class="relative px-6 mx-auto max-w-6xl">
      <div class="max-w-xl">
        <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight">Your smile deserves<br/><span class="text-sky">modern care.</span></h1>
        <p class="mt-4 text-lg text-white/80">Family dentistry in downtown Greenville. Online booking. Same-day emergencies. Accepting new patients.</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href={SITE.bookingUrl} class="rounded-lg bg-blue px-6 py-3 text-center font-medium text-white hover:bg-blue-dark transition-colors">Book Online</a>
          <a href={`tel:${SITE.phone}`} class="rounded-lg bg-white/10 border border-white/30 px-6 py-3 text-center font-medium text-white hover:bg-white/20 transition-colors">Call {SITE.phone}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Inline AI Chat -->
  <section class="bg-blue-light/30 py-8 px-6">
    <div class="mx-auto max-w-xl">
      <div class="flex items-center gap-3 mb-4">
        <img src="https://images.unsplash.com/photo-1588776814546-1ffcf47267a5?w=200&q=80" alt="Greenville Family Dental" class="w-12 h-12 rounded-full object-cover border-2 border-blue/20 shadow-sm" />
        <div>
          <p class="text-sm font-semibold text-charcoal">Ask Greenville Family Dental</p>
          <p class="text-xs text-muted">Insurance, services, booking, emergencies</p>
        </div>
      </div>
      <div class="rounded-xl border border-blue/15 bg-white overflow-hidden">
        <div id="chat-messages" class="hidden max-h-80 overflow-y-auto px-4 pt-4 pb-2 space-y-3"></div>
        <div id="chat-quick" class="flex gap-2 px-3 py-2.5 overflow-x-auto border-b border-blue/10">
          <button class="chat-q shrink-0 rounded-full border border-blue/15 bg-blue/5 px-3 py-1.5 text-xs font-medium text-blue hover:bg-blue/10 transition-colors" data-msg="Do you accept Delta Dental?">Insurance</button>
          <button class="chat-q shrink-0 rounded-full border border-blue/15 bg-blue/5 px-3 py-1.5 text-xs font-medium text-blue hover:bg-blue/10 transition-colors" data-msg="I have a dental emergency">Emergency</button>
          <button class="chat-q shrink-0 rounded-full border border-blue/15 bg-blue/5 px-3 py-1.5 text-xs font-medium text-blue hover:bg-blue/10 transition-colors" data-msg="What are your hours?">Hours</button>
        </div>
        <div class="flex gap-2 p-3">
          <input id="chat-input" type="text" placeholder="Ask about services, insurance, booking..." maxlength="500" autocomplete="off" class="flex-1 rounded-lg border border-blue/15 bg-clean px-5 py-2.5 text-sm text-charcoal placeholder:text-muted focus:border-blue focus:outline-none" />
          <button id="chat-send" class="rounded-lg bg-blue px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-dark transition-colors">Ask</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-20 px-6">
    <div class="mx-auto max-w-4xl">
      <h2 class="reveal text-3xl font-bold text-center mb-2">Our Services</h2>
      <p class="text-center text-muted text-sm mb-10">Comprehensive dental care for the whole family.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {SERVICES.map((s) => (
          <div class="rounded-xl border border-blue/10 bg-white p-5 hover:shadow-md hover:-translate-y-1 hover:border-blue/25 transition-all duration-300">
            <div class="text-2xl mb-2">{s.icon}</div>
            <h3 class="font-semibold text-charcoal">{s.name}</h3>
            <p class="text-sm text-muted mt-2 leading-relaxed">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Providers -->
  <section id="providers" class="py-20 px-6 bg-white">
    <div class="mx-auto max-w-4xl">
      <h2 class="reveal text-3xl font-bold text-center mb-10">Meet Our Team</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {PROVIDERS.map((p) => (
          <div class="text-center">
            <div class="w-32 h-32 rounded-full overflow-hidden mx-auto mb-4"><img src={p.image} alt={p.name} class="w-full h-full object-cover hover:scale-110 transition-transform duration-300" loading="lazy" /></div>
            <h3 class="font-semibold">{p.name}</h3>
            <p class="text-sm text-blue">{p.role}</p>
            <p class="text-xs text-muted mt-2 leading-relaxed">{p.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- New Patient -->
  <section id="new-patient" class="py-16 px-6 bg-blue text-center">
    <div class="mx-auto max-w-lg">
      <h2 class="text-2xl font-bold text-white mb-3">New Patient? Start Here.</h2>
      <p class="text-white/80 text-sm mb-6">Complete your intake forms online before your visit. Save time. Skip the clipboard.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="#" class="rounded-lg bg-white text-blue font-medium px-6 py-3 hover:bg-white/90 transition-colors">Fill Out Forms Online</a>
        <a href={SITE.bookingUrl} class="rounded-lg border border-white/30 text-white font-medium px-6 py-3 hover:bg-white/10 transition-colors">Book Your First Visit</a>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-20 px-6">
    <div class="mx-auto max-w-3xl">
      <h2 class="reveal text-3xl font-bold text-center mb-10">What to Expect</h2>
      <div class="grid md:grid-cols-3 gap-8 text-center">
        {WHAT_TO_EXPECT.map((s) => (
          <div class="reveal">
            <div class="w-14 h-14 rounded-full bg-blue/10 text-blue flex items-center justify-center mx-auto mb-4 text-xl font-bold">{s.step}</div>
            <h3 class="font-semibold text-charcoal">{s.title}</h3>
            <p class="text-sm text-muted mt-2 leading-relaxed">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Insurance -->
  <section id="insurance" class="py-20 px-6 bg-white">
    <div class="mx-auto max-w-3xl">
      <h2 class="reveal text-3xl font-bold text-center mb-2">Insurance We Accept</h2>
      <p class="text-center text-muted text-sm mb-8">Don't see yours? <a href={`tel:${SITE.phone}`} class="text-blue font-medium hover:underline">Call us</a> — we work with most major providers.</p>
      <div class="flex flex-wrap justify-center gap-2">
        {INSURANCE.map((ins) => (
          <span class="rounded-full border border-blue/15 bg-blue/5 px-5 py-2.5 text-sm font-medium text-charcoal">{ins}</span>
        ))}
      </div>
      <p class="text-center text-xs text-muted mt-6">No insurance? Ask about our in-house dental savings plan. We also accept CareCredit.</p>
    </div>
  </section>

  <!-- Emergency -->
  <section class="py-10 px-6">
    <div class="mx-auto max-w-2xl">
      <div class="reveal rounded-xl border border-red-200 bg-red-50 p-6 flex flex-col sm:flex-row items-center gap-4">
        <span class="text-3xl">🚨</span>
        <div class="flex-1 text-center sm:text-left">
          <h3 class="font-bold text-red-800">Dental Emergency?</h3>
          <p class="text-sm text-red-700 mt-1">Same-day appointments for toothaches, broken teeth, and infections.</p>
        </div>
        <a href={`tel:${SITE.phone}`} class="shrink-0 rounded-lg bg-red-600 text-white px-5 py-2.5 font-medium hover:bg-red-700 transition-colors">{SITE.phone}</a>
      </div>
    </div>
  </section>

  <!-- Contact / Visit -->
  <section id="contact" class="py-20 px-6 bg-white">
    <div class="mx-auto max-w-4xl grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-3xl font-bold mb-6">Visit Us</h2>
        <div class="space-y-4 text-sm">
          <div>
            <p class="font-medium text-charcoal">Address</p>
            <p class="text-muted">{SITE.address}</p>
          </div>
          <div>
            <p class="font-medium text-charcoal">Phone</p>
            <p class="text-muted"><a href={`tel:${SITE.phone}`} class="hover:text-blue">{SITE.phone}</a></p>
          </div>
          <div>
            <p class="font-medium text-charcoal">Hours</p>
            {Object.entries(HOURS).map(([day, hours]) => (
              <p class="text-muted"><span class="text-charcoal">{day}:</span> {hours}</p>
            ))}
          </div>
          <div>
            <p class="font-medium text-charcoal">Emergency?</p>
            <p class="text-muted">Call us for same-day emergency appointments. We prioritize toothaches, infections, and broken teeth.</p>
          </div>
        </div>
      </div>
      <div class="rounded-xl overflow-hidden">
        <img src="https://images.unsplash.com/photo-1606811841689-23dfddce3e95?w=600&q=80" alt="Dental office" class="w-full h-full object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-12 px-6 bg-clean text-center">
    <blockquote class="mx-auto max-w-xl">
      <p class="text-lg italic leading-relaxed">"I used to dread the dentist. Dr. Patel changed that completely. She explains everything, never rushes, and my kids actually ask to go back."</p>
      <cite class="mt-4 block text-sm text-muted not-italic">— Amanda R., patient since 2022</cite>
    </blockquote>
  </section>

  <!-- Final CTA -->
  <section class="py-12 px-6 bg-blue text-center">
    <h2 class="text-2xl font-bold text-white">Ready for your best smile?</h2>
    <p class="text-white/80 text-sm mt-2">Book online in 30 seconds. New patients welcome.</p>
    <a href={SITE.bookingUrl} class="inline-block mt-6 rounded-lg bg-white text-blue font-medium px-8 py-3 hover:bg-white/90 transition-colors">Book Your Appointment</a>
  </section>

  <script>
    const chatInput = document.getElementById('chat-input') as HTMLInputElement
    const chatSend = document.getElementById('chat-send')!
    const chatMessages = document.getElementById('chat-messages')!
    const chatQuick = document.getElementById('chat-quick')!
    const chatHistory: Array<{ role: string; content: string }> = []
    let chatBusy = false
    function escapeHtml(t: string): string { return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/\n/g,'<br />') }
    function linkify(h: string): string {
      h = h.replace(/\(864\)\s*555-9120/g, '<a href="tel:+18645559120" class="text-blue underline">(864) 555-9120</a>')
      h = h.replace(/hello@greenvillefamilydental\.com/g, '<a href="mailto:hello@greenvillefamilydental.com" class="text-blue underline">hello@greenvillefamilydental.com</a>')
      return h
    }
    function addMsg(role: string, text: string) {
      chatMessages.classList.remove('hidden')
      const el = document.createElement('div'); el.className = role === 'user' ? 'flex justify-end' : 'flex justify-start'
      const bubble = document.createElement('div')
      bubble.className = role === 'user' ? 'bg-blue/8 text-charcoal rounded-xl rounded-tr-sm px-4 py-2.5 max-w-[80%] text-sm leading-relaxed' : 'bg-clean text-charcoal rounded-xl rounded-tl-sm px-4 py-2.5 max-w-[80%] text-sm leading-relaxed border border-blue/8'
      bubble.innerHTML = role === 'user' ? escapeHtml(text) : linkify(escapeHtml(text))
      el.appendChild(bubble); chatMessages.appendChild(el); chatMessages.scrollTop = chatMessages.scrollHeight
    }
    function showTyping() {
      const el = document.createElement('div'); el.id = 'typing-indicator'; el.className = 'flex justify-start'
      el.innerHTML = '<div class="bg-clean border border-blue/8 rounded-xl rounded-tl-sm px-4 py-2.5"><div class="flex gap-1.5 items-center h-5"><span class="w-1.5 h-1.5 rounded-full bg-blue/30 animate-bounce"></span><span class="w-1.5 h-1.5 rounded-full bg-blue/30 animate-bounce" style="animation-delay:.15s"></span><span class="w-1.5 h-1.5 rounded-full bg-blue/30 animate-bounce" style="animation-delay:.3s"></span></div></div>'
      chatMessages.appendChild(el); chatMessages.scrollTop = chatMessages.scrollHeight
    }
    async function sendChat(text: string) {
      if (!text || chatBusy) return; chatBusy = true; chatInput.value = ''; addMsg('user', text); showTyping()
      try {
        const res = await fetch('/api/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: text, history: chatHistory }) })
        document.getElementById('typing-indicator')?.remove()
        const data = await res.json(); const reply = data.reply || 'Not sure — call us at (864) 555-9120!'
        addMsg('assistant', reply); chatHistory.push({ role: 'user', content: text }); chatHistory.push({ role: 'assistant', content: reply })
        if (chatHistory.length > 20) chatHistory.splice(0, chatHistory.length - 20)
      } catch { document.getElementById('typing-indicator')?.remove(); addMsg('assistant', 'Something went wrong. Call us at (864) 555-9120!') }
      chatBusy = false; chatInput.focus()
    }
    chatSend.addEventListener('click', () => sendChat(chatInput.value.trim()))
    chatInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendChat(chatInput.value.trim()) })
    document.querySelectorAll('.chat-q').forEach(btn => { btn.addEventListener('click', () => { sendChat((btn as HTMLElement).dataset.msg!); chatQuick.remove() }) })
  </script>
</Layout>
