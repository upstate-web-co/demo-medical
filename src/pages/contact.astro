---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE, HOURS } from '../lib/config'

const title = `Contact ${SITE.name} — Get in Touch`
const description = `Reach ${SITE.name} in Greenville, SC. Send us a message, call, or stop by during office hours. New patients always welcome.`

const contactPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contact ${SITE.name}`,
  url: SITE.url + '/contact',
  mainEntity: {
    '@type': 'Organization',
    name: SITE.name,
    email: SITE.email,
    telephone: SITE.phone,
    address: {
      '@type': 'PostalAddress',
      streetAddress: '123 Riverside Way, Suite 200',
      addressLocality: 'Greenville',
      addressRegion: 'SC',
      postalCode: '29601',
      addressCountry: 'US',
    },
  },
}
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(contactPageJsonLd)} />

  <section class="py-16 px-6 bg-white">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-medium text-blue uppercase tracking-wider">Contact</p>
      <h1 class="mt-2 text-4xl md:text-5xl font-bold leading-tight">Get in touch.</h1>
      <p class="mt-4 text-lg text-muted">
        Questions, appointment requests, insurance checks — send us a message and
        we'll respond within one business day.
      </p>
    </div>
  </section>

  <section class="py-12 px-6 bg-clean">
    <div class="mx-auto max-w-5xl grid md:grid-cols-[1fr_1.2fr] gap-10">
      <aside class="space-y-6 text-sm">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">Address</h2>
          <p class="mt-1 text-charcoal">{SITE.address}</p>
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">Phone</h2>
          <p class="mt-1">
            <a href={`tel:${SITE.phone}`} class="text-blue rounded hover:text-blue-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">{SITE.phone}</a>
          </p>
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">Email</h2>
          <p class="mt-1">
            <a href={`mailto:${SITE.email}`} class="text-blue rounded hover:text-blue-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">{SITE.email}</a>
          </p>
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">Hours</h2>
          <dl class="mt-1 space-y-0.5 text-charcoal">
            {Object.entries(HOURS).map(([day, hours]) => (
              <div class="flex gap-2">
                <dt class="min-w-[5rem] text-muted">{day}</dt>
                <dd>{hours}</dd>
              </div>
            ))}
          </dl>
        </div>
      </aside>

      <div>
        <form id="contact-form" class="space-y-4 rounded-xl border border-blue/10 bg-white p-6" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium text-charcoal mb-1">Your name</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              minlength="2"
              autocomplete="name"
              class="w-full rounded-lg border border-blue/20 px-4 py-2.5 text-sm bg-blue-light/10 focus:border-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-charcoal mb-1">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full rounded-lg border border-blue/20 px-4 py-2.5 text-sm bg-blue-light/10 focus:border-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-charcoal mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              required
              minlength="10"
              rows="5"
              class="w-full rounded-lg border border-blue/20 px-4 py-2.5 text-sm bg-blue-light/10 focus:border-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500"
            ></textarea>
          </div>

          <div class="honeypot" aria-hidden="true">
            <label for="website">Website</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <button
            type="submit"
            class="w-full rounded-lg bg-blue px-6 py-3 font-medium text-white hover:bg-blue-dark transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
          >
            Send message
          </button>

          <div id="contact-status" class="hidden rounded-lg p-3 text-center text-sm" role="status" aria-live="polite"></div>
        </form>
      </div>
    </div>
  </section>

  <style>
    .honeypot {
      position: absolute;
      left: -10000px;
      top: auto;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
  </style>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null
    const status = document.getElementById('contact-status') as HTMLDivElement | null

    function setStatus(message: string, tone: 'ok' | 'err') {
      if (!status) return
      status.textContent = message
      status.className = tone === 'ok'
        ? 'rounded-lg p-3 text-center text-sm bg-blue/10 border border-blue/20 text-blue-dark'
        : 'rounded-lg p-3 text-center text-sm bg-red-50 border border-red-200 text-red-800'
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault()
      if (!form) return
      const data = Object.fromEntries(new FormData(form).entries())
      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement
      submit.disabled = true
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })
        if (res.status === 201) {
          setStatus("Thanks — we'll be in touch within one business day.", 'ok')
          form.reset()
        } else if (res.status === 400) {
          const body = await res.json().catch(() => ({})) as { error?: string }
          setStatus(body.error || 'Please check your entries and try again.', 'err')
        } else {
          setStatus('Something went wrong. Please try again or give us a call.', 'err')
        }
      } catch {
        setStatus('Network error. Please try again.', 'err')
      } finally {
        submit.disabled = false
      }
    })
  </script>
</BaseLayout>
